{
  "version": "62.0.0",
  "entity": "question",
  "immutable_fields": [
    "id",
    "public_id",
    "created_year"
  ],
  "editable_fields": [
    "exam",
    "category",
    "skill",
    "difficulty",
    "question",
    "passage",
    "choices",
    "correct",
    "answer",
    "explain",
    "explanation",
    "hint",
    "image",
    "image_alt",
    "image_caption",
    "keywords",
    "concept_id",
    "summary_block_id",
    "misconception_id",
    "time_per_question_sec",
    "editorial_status",
    "release_eligible",
    "summary_id",
    "misconception_block_id",
    "linked_summary_title",
    "linked_block_title",
    "linked_block_excerpt"
  ],
  "image_rules": {
    "preferred_format": "svg_or_webp",
    "transparent_background_preferred": true,
    "max_display_height_px": 290,
    "zoom_enabled": true,
    "alt_text_required": true
  },
  "explanation_rules": {
    "summary_required": true,
    "steps_optional": true,
    "trap_optional": true,
    "similar_choices_only_when_relevant": true,
    "hint_optional": true
  },
  "knowledge_link_rules": {
    "summary_id_required_when_available": true,
    "summary_block_id_required_for_published_physics_questions": true,
    "keywords_hidden_from_student": true,
    "deep_link_enabled": true
  }
}