{
  "version": 4,
  "general": {
    "app_name": "سهيل",
    "tagline": "سهيل يختصر لك الطريق",
    "splash_seconds": 3,
    "maintenance_mode": false,
    "default_language": "ar",
    "support_email": "",
    "terms_version": "draft-1",
    "privacy_version": "draft-1",
    "release": "54.0.0"
  },
  "learning": {
    "daily_question_goal": 20,
    "daily_summary_goal": 1,
    "daily_error_goal": 5,
    "default_session_minutes": 20,
    "max_exam_questions": 25,
    "enable_prediction": true,
    "prediction_min_attempts": 3,
    "spaced_repetition_days": [
      1,
      3,
      7,
      14,
      30
    ],
    "readiness_label": "مؤشر جاهزيتك في سهيل",
    "empty_state_guidance": true,
    "daily_session_primary_action": true
  },
  "diagnostic": {
    "qudrat_scientific": {
      "quant": 6,
      "verbal": 6
    },
    "qudrat_literary": {
      "quant": 4,
      "verbal": 8
    },
    "tahsili_common": {
      "math": 3,
      "physics": 3,
      "chemistry": 3,
      "biology": 3
    },
    "allow_retake_after_days": 7,
    "separate_records": true,
    "allow_both_exam_goals": true,
    "qudrat_requires_academic_track": true,
    "tahsili_ignores_academic_track": true
  },
  "streak": {
    "enabled": true,
    "rescue_window_hours": 6,
    "minimum_activity": "answer_or_summary",
    "freeze_tokens_enabled": false,
    "live_countdown": true,
    "server_time_required_for_production": true,
    "icon_style": "svg"
  },
  "challenges": {
    "enabled": true,
    "friend_limit": 50,
    "daily_question_count": 10,
    "weekly_question_count": 35,
    "invite_expiry_hours": 48,
    "allow_rematch": true
  },
  "notifications": {
    "enabled": true,
    "daily_plan": true,
    "streak_warning": true,
    "challenge_invites": true,
    "review_due": true,
    "quiet_hours_start": "22:30",
    "quiet_hours_end": "07:00"
  },
  "content": {
    "require_reviewer_approval": true,
    "duplicate_threshold": 0.8,
    "require_explanation": true,
    "require_skill_tag": true,
    "require_source": true,
    "question_statuses": [
      "draft",
      "review",
      "changes_requested",
      "approved",
      "published",
      "archived"
    ],
    "require_rights_clearance": true,
    "minimum_reviewers": 1
  },
  "features": {
    "summaries": true,
    "friends": true,
    "challenges": true,
    "xp": true,
    "ads": false,
    "ai_drafts": true,
    "independent_diagnostics": true,
    "tahsili_common_for_all": true,
    "qudrat_academic_tracks": true
  },
  "performance": {
    "prefer_webp": true,
    "question_page_size": 50,
    "summary_page_size": 100,
    "client_cache_minutes": 15,
    "preload_next_question": true,
    "lazy_question_api": true,
    "initial_payload_target_kb": 900,
    "asset_cdn_ready": true,
    "gzip_api": true
  },
  "navigation": {
    "main_pages": [
      "homePage",
      "reviewPage",
      "summariesPage",
      "tasksPage",
      "statsPage",
      "profilePage",
      "challengePage",
      "studentSetupPage",
      "diagnosticChoicePage",
      "adminSettingsPage"
    ],
    "summary_detail_mode": "lift",
    "exam_mode": "hidden",
    "safe_area": true,
    "home_emphasis": "balanced"
  },
  "admin": {
    "settings_source": "api_with_local_fallback",
    "require_publish_action": true,
    "audit_log": true,
    "role_separation": true,
    "production_auth_required": true
  },
  "security": {
    "client_auth_mode": "development_only",
    "api_auth_mode": "pbkdf2_token",
    "remove_plaintext_passwords": true,
    "admin_token_required": true,
    "rate_limit_ready": true
  }
}